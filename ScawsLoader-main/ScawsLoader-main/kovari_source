local Util = {}

function Util.Create(className, properties)
    local inst = Instance.new(className)
    for k, v in pairs(properties or {}) do
        if k ~= "Parent" then pcall(function() inst[k] = v end) end
    end
    if properties and properties.Parent then inst.Parent = properties.Parent end
    return inst
end

function Util.Tween(obj, props, dur, style, dir)
    if not obj then return end
    local ti = TweenInfo.new(dur or Theme.NormalSpeed, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out)
    local tw = TweenService:Create(obj, ti, props)
    tw:Play()
    return tw
end

function Util.Spring(obj, props, spd)
    if not obj then return end
    local ti = TweenInfo.new(spd or Theme.SpringSpeed, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    local tw = TweenService:Create(obj, ti, props)
    tw:Play()
    return tw
end

function Util.SmoothTween(obj, props, dur)
    if not obj then return end
    local ti = TweenInfo.new(dur or Theme.NormalSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
    local tw = TweenService:Create(obj, ti, props)
    tw:Play()
    return tw
end

