local KOVARI_DEFAULT_SCRIPT_URL = "https://scawshub.vercel.app/kovari"
local RIVALS_SCRIPT_URL = "https://scawshub.vercel.app/luau/Kovari_Rivals.luau"
local RIVALS_PLACE_ID = 17625359962
local RIVALS_GAME_ID = 6035872082

local queueteleport = (type(queue_on_teleport) == "function" and queue_on_teleport)
    or (type(syn) == "table" and type(syn.queue_on_teleport) == "function" and syn.queue_on_teleport)
    or (type(fluxus) == "table" and type(fluxus.queue_on_teleport) == "function" and fluxus.queue_on_teleport)
    or nil

local function QueueTeleportScript(key, scriptURL)
    local fallbackUrl = scriptURL or KOVARI_DEFAULT_SCRIPT_URL
    if not queueteleport then
        -- queue_on_teleport not available
        return
    end

    local loaderLogic = string.format([[
        if not game:IsLoaded() then game.Loaded:Wait() end
        local CoreGui = game:GetService("CoreGui")
        while not CoreGui do task.wait() CoreGui = game:GetService("CoreGui") end
        local Players = game:GetService("Players")
        while not Players.LocalPlayer do task.wait() end
        
        -- Determine URL based on Game/Place ID
        local url = %q
        if game.PlaceId == %d or game.GameId == %d then
            url = %q
        end

        local success = false
        for attempt = 1, 5 do
            local s, res = pcall(function()
                return game:HttpGet(url)
            end)
            if s and type(res) == "string" and res ~= "" and not res:match("404: Not Found") then
                local execSuccess, execErr = pcall(function()
                    loadstring(res)()
                end)
                if not execSuccess then
                    -- execution error on teleport
                end
                success = true
                break
            else
                -- fetch retry
            end
            task.wait(3)
        end
        -- silent fail
    ]], fallbackUrl, RIVALS_PLACE_ID, RIVALS_GAME_ID, RIVALS_SCRIPT_URL)

    local teleportScript
    if key and key ~= "" then
        teleportScript = string.format([[
getgenv().KOVARI_SAVED_KEY = %q
%s
]], key, loaderLogic)
    else
        teleportScript = loaderLogic
    end
    local success, err = pcall(queueteleport, teleportScript)
    if success then
        -- queued
    else
        -- queue failed
    end
end

