    -- ═══ Stagger animation ═══
    local function AnimateElement(element, delay)
        delay = delay or 0
        local origBgT = element.BackgroundTransparency
        local origPos = element.Position
        local children = {}
        for _, ch in ipairs(element:GetDescendants()) do
            if ch:IsA("TextLabel") or ch:IsA("TextButton") or ch:IsA("TextBox") then
                table.insert(children, {obj=ch, orig=ch.TextTransparency})
            elseif ch:IsA("ImageLabel") and ch.Name ~= "Shadow" and ch.Name ~= "Glow" then
                table.insert(children, {obj=ch, orig=ch.ImageTransparency, img=true})
            elseif ch:IsA("UIStroke") then
                table.insert(children, {obj=ch, orig=ch.Transparency, stroke=true})
            end
        end
        element.BackgroundTransparency = 1
        element.Position = UDim2.new(origPos.X.Scale, origPos.X.Offset, origPos.Y.Scale, origPos.Y.Offset + 16)
        for _, d in ipairs(children) do
            if d.img then d.obj.ImageTransparency = 1
            elseif d.stroke then d.obj.Transparency = 1
            else d.obj.TextTransparency = 1 end
        end
        task.delay(delay, function()
            if not element or not element.Parent then return end
            Util.Tween(element, {Position = origPos}, 0.4, Enum.EasingStyle.Quart)
            Util.Tween(element, {BackgroundTransparency = origBgT}, 0.3)
            for i, d in ipairs(children) do
                if d.obj and d.obj.Parent then
                    task.delay(i * 0.01, function()
                        if d.img then Util.Tween(d.obj, {ImageTransparency = d.orig}, 0.35)
                        elseif d.stroke then Util.Tween(d.obj, {Transparency = d.orig}, 0.35)
                        else Util.Tween(d.obj, {TextTransparency = d.orig}, 0.35) end
                    end)
                end
            end
        end)
    end

