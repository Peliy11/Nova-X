local Animate = {}

function Animate.FadeIn(object, duration, delay)
    delay = delay or 0; duration = duration or Theme.NormalSpeed
    if object:IsA("GuiObject") then
        local orig = object:GetAttribute("TargetBgTransparency") or 0
        object.BackgroundTransparency = 1
        task.delay(delay, function() Util.Tween(object, {BackgroundTransparency = orig}, duration) end)
    end
end

function Animate.SlideIn(object, direction, duration, delay)
    delay = delay or 0; duration = duration or Theme.NormalSpeed; direction = direction or "left"
    if not object:IsA("GuiObject") then return end
    local origPos = object.Position
    local off = ({left={-40,0}, right={40,0}, up={0,-40}, down={0,40}})[direction] or {-40,0}
    object.Position = UDim2.new(origPos.X.Scale, origPos.X.Offset + off[1], origPos.Y.Scale, origPos.Y.Offset + off[2])
    task.delay(delay, function() Util.Spring(object, {Position = origPos}, duration) end)
end

function Animate.FadeOut(object, duration, callback)
    duration = duration or Theme.NormalSpeed
    if object:IsA("GuiObject") then Util.Tween(object, {BackgroundTransparency = 1}, duration) end
    for _, child in ipairs(object:GetDescendants()) do
        if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
            Util.Tween(child, {TextTransparency = 1}, duration)
        elseif child:IsA("ImageLabel") then
            Util.Tween(child, {ImageTransparency = 1}, duration)
        elseif child:IsA("UIStroke") then
            Util.Tween(child, {Transparency = 1}, duration)
        end
    end
    if callback then task.delay(duration, callback) end
end

