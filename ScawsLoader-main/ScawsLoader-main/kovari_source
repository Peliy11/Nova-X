function Util.FormatDate(timestamp)
    local d = os.date("*t", timestamp)
    local months = {"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"}
    return string.format("%s %d, %d", months[d.month], d.day, d.year)
end

