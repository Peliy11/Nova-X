    end

    CreateProfileTab()

    -- ═══ Toggle keybind ═══
    table.insert(Connections, UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == toggleKey and not Toggling then
            Toggling = true
            UIVisible = not UIVisible
            if UIVisible then
                FloatingBtn.Visible = false
                Main.Visible = true
                Main.Size = UDim2.new(0, 620, 0, 0)
                Util.Spring(Main, {Size = UDim2.new(0, 620, 0, 420)}, Theme.SpringSpeed)
                task.delay(Theme.SpringSpeed, function() Toggling = false end)
            else
                Util.Tween(Main, {Size = UDim2.new(0, 620, 0, 0)}, Theme.NormalSpeed, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
                task.delay(Theme.NormalSpeed, function()
                    if not UIVisible then
                        Main.Visible = false
                        FloatingBtn.Visible = true
                        FloatingBtn.Size = UDim2.new(0, 0, 0, 0)
                        Util.Spring(FloatingBtn, {Size = UDim2.new(0, 48, 0, 48)}, 0.25)
                    end
                    Toggling = false
                end)
            end
        end
    end))

    -- ═══════════════════════════════════════════════════════════════
    -- PUBLIC API
    -- ═══════════════════════════════════════════════════════════════
    local API = {
        Gui = ScreenGui,
        Main = Main,
        Theme = Theme,

        CreateTab = function(_, name, isDefault)
            local tab = CreateTab(name, #AllTabs, isDefault)
            local TabAPI = {}
            function TabAPI:AddSection(sectionName)
                return CreateSection(tab.Content, sectionName)
            end
            return TabAPI
        end,

        SetStatus = function(_, text, color)
            StatusText.Text = text
            StatusText.TextColor3 = color or Theme.TextSecondary
            StatusDot.BackgroundColor3 = color or Theme.TextSecondary
        end,

        SetToggleKey = function(_, key) toggleKey = key end,

        SetScale = function(_, scale)
            UIScaleValue = scale
            Util.Tween(UIScale, {Scale = scale / 100}, Theme.QuickSpeed)
        end,

        Destroy = function(_)
            for _, c in ipairs(Connections) do c:Disconnect() end
            FadeAllChildren(Main, Theme.QuickSpeed)
            Util.Tween(Main, {Size = UDim2.new(0, 600, 0, 0), BackgroundTransparency = 1}, Theme.NormalSpeed, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
            task.delay(Theme.NormalSpeed + 0.1, function()
                ScreenGui:Destroy()
                _G.KovariLoaded = false
                _G.KovariInstance = nil
            end)
        end,

        Notify = function(_, title, message, duration)
            duration = duration or 3

            local NotifFrame = Util.Create("Frame", {
                AnchorPoint = Vector2.new(1, 1),
                Position = UDim2.new(1, 20, 1, -20),
                Size = UDim2.new(0, 300, 0, 78),
                BackgroundColor3 = Theme.Elevated,
                Parent = ScreenGui
            })
            Util.Corner(NotifFrame, Theme.CornerRadius)
            Util.Stroke(NotifFrame, Theme.CardBorder, 1, 0.4)
            Util.Shadow(NotifFrame, 6, 0.4)

            -- Accent bar
            Util.Create("Frame", {
                Size = UDim2.new(0, 3, 1, -16),
                Position = UDim2.new(0, 12, 0, 8),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel = 0,
                Parent = NotifFrame
            })
            Util.Corner(Util.Create("Frame", {
                Size = UDim2.new(0, 3, 1, -16),
                Position = UDim2.new(0, 12, 0, 8),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel = 0,
                Parent = NotifFrame
            }), 2)

            Util.Create("TextLabel", {
                Size = UDim2.new(1, -34, 0, 18),
                Position = UDim2.new(0, 22, 0, 14),
                BackgroundTransparency = 1,
                Font = Theme.FontBold,
                Text = title or "Notification",
                TextColor3 = Theme.TextPrimary,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = NotifFrame
            })

            Util.Create("TextLabel", {
                Size = UDim2.new(1, -34, 0, 28),
                Position = UDim2.new(0, 22, 0, 36),
                BackgroundTransparency = 1,
                Font = Theme.FontMedium,
                Text = message or "",
                TextColor3 = Theme.TextSecondary,
                TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true,
                Parent = NotifFrame
            })

            -- Progress
            local ProgressTrack = Util.Create("Frame", {
                AnchorPoint = Vector2.new(0.5, 1),
                Size = UDim2.new(1, -24, 0, 2),
                Position = UDim2.new(0.5, 0, 1, -6),
                BackgroundColor3 = Theme.Fill,
                BorderSizePixel = 0,
                Parent = NotifFrame
            })
            Util.Corner(ProgressTrack, 1)

            local ProgressFill = Util.Create("Frame", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel = 0,
                Parent = ProgressTrack
            })
            Util.Corner(ProgressFill, 1)

            -- Slide in
            Util.Spring(NotifFrame, {Position = UDim2.new(1, -20, 1, -20)}, Theme.NormalSpeed)
            Util.Tween(ProgressFill, {Size = UDim2.new(0, 0, 1, 0)}, duration, Enum.EasingStyle.Linear)

            task.delay(duration, function()
                Util.Tween(NotifFrame, {Position = UDim2.new(1, 20, 1, -20)}, 0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
                task.delay(0.25, function() NotifFrame:Destroy() end)
            end)
        end
    }

    -- ═══ Built-in Settings Tab ═══
    local SettingsTab = API:CreateTab("Settings", false)

    -- Appearance section with theme picker
    local oldCfg = nil
    pcall(function()
        if isfile and isfile("KovariSettings.json") then
            oldCfg = HttpService:JSONDecode(readfile("KovariSettings.json"))
        end
    end)
    oldCfg = oldCfg or {}

    local function SaveConfig(key, val)
        oldCfg[key] = val
        pcall(function()
            if writefile then
                writefile("KovariSettings.json", HttpService:JSONEncode(oldCfg))
            end
        end)
    end

    local AppearanceSection = SettingsTab:AddSection("Appearance")
    local presetNames = {"Default", "Ocean", "Rose", "Emerald", "Sunset", "Crimson", "Midnight"}
    local dropdownInst = AppearanceSection:AddDropdown({
        Name = "Theme",
        Options = presetNames,
        Default = oldCfg.Theme or "Default",
        Callback = function(preset)
            SaveConfig("Theme", preset)
            local themeKeys = {
                "Accent", "AccentLight", "AccentDark", "AccentMuted", "AccentGlow",
                "AccentSurface", "AccentSurfaceHover", "BorderFocus",
                "Primary", "Secondary", "Tertiary", "Elevated", "Card", "CardHover", "CardBorder"
            }

            local oldToNew = {}
            local oldValues = {}
            for _, key in ipairs(themeKeys) do
                oldValues[key] = Theme[key]
            end

            for k, v in pairs(DefaultTheme) do Theme[k] = v end
            if preset ~= "Default" then
                ApplyThemeCustomization(preset, nil)
            end

            for _, key in ipairs(themeKeys) do
                local oldStr = tostring(oldValues[key])
                if oldStr ~= tostring(Theme[key]) then
                    oldToNew[oldStr] = Theme[key]
                end
            end

            for _, obj in ipairs(ScreenGui:GetDescendants()) do
                if obj:IsA("GuiObject") then
                    local bgStr = tostring(obj.BackgroundColor3)
                    if oldToNew[bgStr] then
                        Util.Tween(obj, {BackgroundColor3 = oldToNew[bgStr]}, 0.35)
                    end
                end
                if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
                    local tcStr = tostring(obj.TextColor3)
                    if oldToNew[tcStr] then
                        Util.Tween(obj, {TextColor3 = oldToNew[tcStr]}, 0.35)
                    end
                end
                if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
                    local icStr = tostring(obj.ImageColor3)
                    if oldToNew[icStr] then
                        Util.Tween(obj, {ImageColor3 = oldToNew[icStr]}, 0.35)
                    end
                end
                if obj:IsA("UIStroke") then
                    local scStr = tostring(obj.Color)
                    if oldToNew[scStr] then
                        Util.Tween(obj, {Color = oldToNew[scStr]}, 0.35)
                    end
                end
                if obj:IsA("ScrollingFrame") then
                    local sbStr = tostring(obj.ScrollBarImageColor3)
                    if oldToNew[sbStr] then
                        Util.Tween(obj, {ScrollBarImageColor3 = oldToNew[sbStr]}, 0.35)
                    end
                end
            end

            API:Notify("Theme", "Switched to " .. preset, 2)
        end
    })

    local UISection = SettingsTab:AddSection("Interface")
    local scaleSlider = UISection:AddSlider({Name = "UI Scale", Min = 50, Max = 150, Default = oldCfg.Scale or 100, Suffix = "%", Callback = function(v) 
        SaveConfig("Scale", v)
        API:SetScale(v)
    end})
    UISection:AddToggle({Name = "Smooth Animations", Default = oldCfg.SmoothAnimations ~= false, Callback = function(state)
        SaveConfig("SmoothAnimations", state)
        if state then Theme.QuickSpeed = 0.12; Theme.NormalSpeed = 0.2; Theme.SlowSpeed = 0.35
        else Theme.QuickSpeed = 0.06; Theme.NormalSpeed = 0.1; Theme.SlowSpeed = 0.15 end
    end})

    local UtilSection = SettingsTab:AddSection("Utility")
    UtilSection:AddButton({Name = "Copy Discord Invite", ButtonText = "Copy", Callback = function()
        pcall(function() (setclipboard or toclipboard or function() end)(discordInvite) end)
        API:Notify("Copied", "Discord invite copied to clipboard!", 2)
    end})
    UtilSection:AddButton({Name = "Rejoin Server", ButtonText = "Rejoin", Callback = function()
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
    end})
    UtilSection:AddButton({Name = "Server Hop", ButtonText = "Hop", Callback = function()
        local s, r = pcall(function()
            local servers = {}
            local req = game:HttpGet(string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100", game.PlaceId))
            local body = HttpService:JSONDecode(req)
            if body and body.data then
                for _, sv in pairs(body.data) do
                    if sv.playing < sv.maxPlayers and sv.id ~= game.JobId then table.insert(servers, sv.id) end
                end
            end
            if #servers > 0 then TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], LocalPlayer)
            else API:Notify("Server Hop", "No available servers found!", 3) end
        end)
        if not s then API:Notify("Error", "Failed: " .. tostring(r), 3) end
    end})

    if oldCfg.Theme and presetNames[oldCfg.Theme] then
        task.defer(function()
            dropdownInst:SetSelected(oldCfg.Theme)
        end)
    end
    if oldCfg.Scale then
        task.defer(function()
            API:SetScale(oldCfg.Scale)
        end)
    end

    local DangerSection = SettingsTab:AddSection("Danger Zone")
    DangerSection:AddButton({Name = "Destroy UI", ButtonText = "Destroy", Callback = function() API:Destroy() end})

    return API
end

-- ═══════════════════════════════════════════════════════════════════
-- ENTRY POINT
-- ═══════════════════════════════════════════════════════════════════
function Kovari:Load(config)
    config = config or {}

    -- Try to apply saved theme right at the very beginning
    local fallbackTheme = config.ThemePreset
    pcall(function()
        if isfile and isfile("KovariSettings.json") then
            local data = HttpService:JSONDecode(readfile("KovariSettings.json"))
            if data and data.Theme then
                fallbackTheme = data.Theme
            end
        end
    end)
    -- Apply theme customization before anything renders
    ApplyThemeCustomization(fallbackTheme, config.Theme)

    -- Store ScriptURL globally so it persists for teleport queueing
    if config.ScriptURL and config.ScriptURL ~= "" then
        getgenv().KOVARI_SCRIPT_URL = config.ScriptURL
    end
    if config.KeySystem then
        local kc = config.KeySystem
        kc.ScriptURL = config.ScriptURL or getgenv().KOVARI_SCRIPT_URL or ""
        kc.OnSuccess = function() self:Init(config) end
        kc.OnFailed = kc.OnFailed or function() end
        return self:CreateKeyUI(kc)
    else
        -- No key system — still queue the script for teleport if ScriptURL provided
        if config.ScriptURL and config.ScriptURL ~= "" and queueteleport then
            local teleportScript = string.format([[loadstring(game:HttpGet(%q))()]], config.ScriptURL)
            pcall(queueteleport, teleportScript)
            -- queued
        end
        return self:Init(config)
    end
end

_G.KovariInstance = Kovari
return Kovari
