                            Size = UDim2.new(0, 18, 1, 0),
                            Position = UDim2.new(1, -4, 0.5, 0),
                            BackgroundTransparency = 1,
                            Font = Theme.FontBold,
                            Text = "✓",
                            TextColor3 = Theme.Accent,
                            TextSize = 11,
                            ZIndex = 10001,
                            Parent = OBtn
                        })
                    end

                    OBtn.MouseEnter:Connect(function() Util.Tween(OBtn, {BackgroundTransparency = 0, TextColor3 = Theme.TextPrimary}, 0.06) end)
                    OBtn.MouseLeave:Connect(function() Util.Tween(OBtn, {BackgroundTransparency = 1, TextColor3 = opt == selected and Theme.Accent or Theme.TextSecondary}, 0.06) end)
                    OBtn.MouseButton1Click:Connect(function()
                        selected = opt; DropBtn.Text = "  " .. selected; CloseDD(); callback(selected)
                    end)
                end
            end
            Populate()

            table.insert(Connections, DropBtn.MouseButton1Click:Connect(function() if isOpen then CloseDD() else OpenDD() end end))

            return {
                SetSelected = function(_, v) selected = v; DropBtn.Text = "  " .. selected end,
                Refresh = function(_, newOpts) options = newOpts; Populate() end
            }
        end

