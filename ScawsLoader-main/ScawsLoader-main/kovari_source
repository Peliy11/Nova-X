            local function Update(input)
                local pct = math.clamp((input.Position.X - TrackFrame.AbsolutePosition.X) / TrackFrame.AbsoluteSize.X, 0, 1)
                value = math.floor(min + (max - min) * pct)
                ValueLabel.Text = tostring(value) .. suffix
                Util.Tween(FillBar, {Size = UDim2.new(pct, 0, 1, 0)}, 0.04)
                Util.Tween(SliderKnob, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.04)
                callback(value)
            end

            table.insert(Connections, Hitbox.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = true; Update(input)
                    Util.Spring(SliderKnob, {Size = UDim2.new(0, 24, 0, 24)}, 0.12)
