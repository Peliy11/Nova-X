-- HELPER: Fade all children out for close animations
-- ═══════════════════════════════════════════════════════════════════
local function FadeAllChildren(frame, dur)
    for _, child in ipairs(frame:GetDescendants()) do
        if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
            Util.Tween(child, {TextTransparency = 1}, dur)
        end
        if child:IsA("Frame") and child.BackgroundTransparency < 1 then
            Util.Tween(child, {BackgroundTransparency = 1}, dur)
        end
        if child:IsA("ImageLabel") then
            Util.Tween(child, {ImageTransparency = 1}, dur)
        end
        if child:IsA("UIStroke") then
            Util.Tween(child, {Transparency = 1}, dur)
        end
    end
end

